      let query = supabase.from('products').select('*').eq('is_available', true)

      if (categoryId) {
        query = query.eq('category_id', categoryId)
      }

      const { data, error } = await query

      if (error) {
        throw new Error(error.message)
      }

      return data as Product[]
    },
  })
}
