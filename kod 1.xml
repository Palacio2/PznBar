                <>{t('confirm_assign', 'Ви дійсно хочете призначити роль')} <span className="uppercase font-bold text-primary">{confirmAction.newRole}</span> {t('to_user', 'користувачу')} <strong>{confirmAction.targetIdentifier}</strong>?</>
