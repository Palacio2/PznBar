                {t('cancel', 'Скасувати')}
              </Button>
              <Button className="flex-1 h-12 rounded-xl" onClick={executeRoleChange}>
                {t('confirm', 'Підтвердити')}
              </Button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
